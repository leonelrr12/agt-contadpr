generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  taxId     String   @unique
  address   String?
  phone     String?
  email     String?
  country   String   @default("PA")
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  accounts       Account[]
  concepts       Concept[]
  transactions   Transaction[]
  journalEntries JournalEntry[]
  subscriptions  Subscription[]
  apiKeys        ApiKey[]
  clients        Client[]
  suppliers      Supplier[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("contador")
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  transactions   Transaction[]
  journalEntries JournalEntry[]
  reviewedEntries JournalEntry[] @relation("ReviewedEntries")
  auditLogs      AuditLog[]
}

model Account {
  id        String   @id @default(cuid())
  code      String
  name      String
  type      String   @default("GASTO")
  parentId  String?
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  concepts     Concept[]
  journalLines JournalLine[]
  rulesFrom    AccountingRuleEntry[]

  @@unique([code, companyId])
}

model Concept {
  id         String   @id @default(cuid())
  name       String
  accountId  String
  companyId  String
  confidence Float    @default(0.9)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([name, companyId])
}

model Transaction {
  id            String   @id @default(cuid())
  type          String
  amount        Float
  currency      String   @default("USD")
  description   String
  concept       String?
  paymentMethod String?
  date          DateTime
  metadata      String   @default("{}")
  companyId     String
  createdById   String
  journalEntryId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company      Company      @relation(fields: [companyId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
}

model JournalEntry {
  id           String    @id @default(cuid())
  date         DateTime
  description  String
  status       String    @default("BORRADOR")
  companyId    String
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  reviewedBy   User?         @relation("ReviewedEntries", fields: [reviewedById], references: [id])
  lines        JournalLine[]
  transactions Transaction[]
}

model JournalLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Float   @default(0)
  credit         Float   @default(0)

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])
}

model AccountingRule {
  id        String   @id @default(cuid())
  name      String
  condition String   @default("{}")
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries AccountingRuleEntry[]
}

model AccountingRuleEntry {
  id        String  @id @default(cuid())
  ruleId    String
  accountId String
  type      String

  rule    AccountingRule @relation(fields: [ruleId], references: [id])
  account Account        @relation(fields: [accountId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  before    String?
  after     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique   // "Demo", "Emprendedor", "Pyme", "Despacho"
  description   String?           // Descripción visible en la UI
  monthlyLimit  Int                // Movimientos por período
  price         Float              // Precio en USD (0 = gratis/demo)
  features      String   @default("[]") // JSON array de funcionalidades
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)    // Orden en la UI
  createdAt     DateTime @default(now())

  subscriptions Subscription[]
  @@map("plan")
}

enum SubscriptionStatus {
  DEMO
  ACTIVE
  EXPIRED
  GRACE
  GRANTED
}

enum PaymentMethod {
  YAPPY
  TRANSFERENCIA
  EFECTIVO
  GRANTED
  OTHER
}

model Subscription {
  id              String             @id @default(cuid())
  companyId       String
  planId          String
  status          SubscriptionStatus @default(DEMO)
  movementsUsed   Int                @default(0)
  movementsLimit  Int                // Límite del período actual (puede diferir del plan)
  periodStart     DateTime           @default(now())
  periodEnd       DateTime
  grantedBy       String?            // userId del admin que otorgó
  grantedNote     String?            // Nota del admin
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  company         Company           @relation(fields: [companyId], references: [id])
  plan            Plan              @relation(fields: [planId], references: [id])
  payments        PaymentRecord[]

  @@index([companyId])
  @@index([status])
  @@map("subscription")
}

model PaymentRecord {
  id             String        @id @default(cuid())
  subscriptionId String
  amount         Float
  method         PaymentMethod @default(TRANSFERENCIA)
  reference      String?       // Número de comprobante / Yappy ID
  receivedBy     String?       // userId del admin que confirmó
  note           String?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("payment_record")
}

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  name       String    // "Producción", "Test", "Zapier"
  keyHash    String    @unique  // SHA-256 del token completo
  prefix     String    @default("sk_live_")
  truncated  String    // "sk_live_8f3a...9b2c" para mostrar en UI
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  isRevoked  Boolean   @default(false)

  company    Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([keyHash])
  @@map("api_key")
}

model Client {
  id         String    @id @default(cuid())
  companyId  String
  name       String
  taxId      String?   // RUC
  phone      String?
  email      String?
  address    String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company    Company   @relation(fields: [companyId], references: [id])
  invoices   Invoice[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("client")
}

model Supplier {
  id            String    @id @default(cuid())
  companyId     String
  name          String
  taxId         String?
  phone         String?
  email         String?
  paymentTerms  String?   @default("30") // días de crédito por defecto
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company   @relation(fields: [companyId], references: [id])
  bills         Bill[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("supplier")
}

model Invoice {
  id             String    @id @default(cuid())
  companyId      String
  clientId       String
  number         String?   // Número de factura emitida
  amount         Float
  itbms          Float     @default(0)
  total          Float
  dueDate        DateTime
  paidAt         DateTime?
  status         String    @default("PENDIENTE") // PENDIENTE, VENCIDA, PAGADA
  date           DateTime  @default(now())
  description    String?
  journalEntryId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client         Client    @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([status])
  @@map("invoice")
}

model Bill {
  id             String    @id @default(cuid())
  companyId      String
  supplierId     String
  number         String?   // Número de factura del proveedor
  amount         Float
  itbms          Float     @default(0)
  total          Float
  dueDate        DateTime
  paidAt         DateTime?
  status         String    @default("PENDIENTE") // PENDIENTE, VENCIDA, PAGADA
  date           DateTime  @default(now())
  description    String?
  journalEntryId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier       Supplier  @relation(fields: [supplierId], references: [id])

  @@index([companyId])
  @@index([supplierId])
  @@index([status])
  @@map("bill")
}

model OCRExample {
  id             String   @id @default(cuid())
  rawText        String
  correctedText  String?
  total          Float?
  date           String?
  provider       String?
  ruc            String?
  itbms          Float?
  imageHash      String?
  confidence     Float    @default(0)
  source         String   @default("tesseract+llm")
  companyId      String   @default("demo-company")
  createdById    String   @default("demo-user")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([provider])
  @@index([companyId])
}
