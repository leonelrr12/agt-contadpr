# Base de datos
DATABASE_URL="postgresql://contador:CHANGE_ME@localhost:5432/agt_contador?schema=public"

# DeepSeek API (LLM)
DEEPSEEK_API_KEY=sk-your-key-here

# JWT Secret — usa un valor aleatorio largo en producción
JWT_SECRET="genera-un-secret-aleatorio-de-64-caracteres"

# CORS — restringe al dominio de producción
CORS_ORIGIN="*"

# ITBMS — tasa estándar Panamá
ITBMS_RATE="0.07"
ITBMS_ENABLED="true"
