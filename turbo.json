{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:generate": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/**"]
    },
    "db:push": {
      "dependsOn": ["^db:generate"]
    },
    "db:seed": {
      "dependsOn": ["^db:push"]
    }
  }
}
